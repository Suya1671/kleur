# Scheme name: {{scheme-name}}
# Scheme author: {{scheme-author}}
# Template author: Tinted Theming (https://github.com/tinted-theming) Modified by Suyashtnt (https://github.com/Suyashtnt)
#
# This file demonstrates all available theme configuration options for Vicinae.
# You don't need to define all of these: only override what you want to customize.
# Undefined colors will be automatically derived from core colors or inherited from base themes.
#
# Check out the full documentation at https://docs.vicinae.com/theming/getting-started

[meta]
name = "{{scheme-name}}"
description = "Generated by Kleur"
variant = "{{polarity}}"
inherits = "vicinae-{{polarity}}"

[colors.core]
accent = "#{{primary-hex}}"
accent_foreground = "#{{background-hex}}"
background = "#{{background-hex}}"
foreground = "#{{base07-hex}}"
secondary_background = "#{{surface-hex}}"
border = "#{{overlay-hex}}"

[colors.main_window]
border = "#{{overlay-hex}}"
footer = { background = "#{{surface-hex}}" }

[colors.settings_window]
border = "#{{overlay-hex}}"

[colors.accents]
blue = "#{{blue-hex}}"
green = "#{{green-hex}}"
magenta = "#{{purple-hex}}"
orange = "#{{orange-hex}}"
red = "#{{red-hex}}"
yellow = "#{{orange-hex}}"
cyan = "#{{teal-hex}}"
purple = "#{{purple-hex}}"

[colors.shortcut]
border = "#{{overlay-hex}}"

[colors.text]
default = "#{{base07-hex}}"
muted = "#{{base03-hex}}"
danger = "#{{red-hex}}"
success = "#{{green-hex}}"
placeholder = "#{{base04-hex}}"
selection = { background = "#{{primary-hex}}", foreground = "#{{base07-hex}}" }

[colors.text.links]
default = "#{{blue-hex}}"
visited = "#{{purple-hex}}"

[colors.input]
border = "#{{overlay-hex}}"
border_focus = "#{{primary-hex}}"
border_error = "#{{red-hex}}"

[colors.button.primary]
background = "#{{overlay-hex}}"
foreground = "#{{background-hex}}"
hover = { background = "#{{base02-hex}}" }
focus = { outline = "#{{primary-hex}}" }

[colors.list.item.selection]
background = "#{{overlay-hex}}"
foreground = "#{{base06-hex}}"
secondary_background = "#{{overlay-hex}}"
secondary_foreground = "#{{base06-hex}}"

[colors.grid.item]
background = "#{{surface-hex}}"
hover = { outline = "#{{base05-hex}}" }
selection = { outline = "#{{base05-hex}}" }

[colors.scrollbars]
background = "#{{overlay-hex}}"

[colors.loading]
bar = "#{{base07-hex}}"
spinner = "#{{base07-hex}}"
