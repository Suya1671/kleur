      "bold": false
    },
    "*.async": "#f8aa14",
    "*.deprecated": {
      "strikethrough": true,
      "foreground": "#bab9be"
    },
    "*.unsafe": {
      "foreground": "#ffa192",
      "bold": true
    },
    "unresolvedReference": "#ffa192",
    "variable.defaultLibrary": "#06d46e",
    "variable.builtin": "#06d46e",
    "*.mutable": {
      "fontStyle": "underline"
    },
    "*.emph": {
      "italic": true
    }
  }
}
